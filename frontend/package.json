{
	"name": "thymis-frontend",
	"version": "0.7.2-dev",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"test": "npm run test:integration && npm run test:unit",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --plugin-search-dir . --check . && eslint .",
		"format": "prettier --plugin-search-dir . --write .",
		"test:integration": "playwright test",
		"test:integration:update-snapshots": "playwright test --update-snapshots",
		"test:unit": "vitest"
	},
	"devDependencies": {
		"@novnc/novnc": "npm:@elikoga/novnc@^1.6.0",
		"@playwright/test": "1.52.0",
		"@prgm/sveltekit-progress-bar": "^3.0.2",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "0.5.11",
		"@tailwindcss/typography": "0.5.19",
		"@tailwindcss/vite": "4.1.18",
		"@types/node": "^25.5.0",
		"@typescript-eslint/eslint-plugin": "^8.57.0",
		"@typescript-eslint/parser": "^8.57.0",
		"@xterm/addon-attach": "^0.12.0",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/addon-webgl": "^0.19.0",
		"@xterm/xterm": "^6.0.0",
		"@zerodevx/svelte-toast": "^0.9.6",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"eslint-plugin-unused-imports": "^4.4.1",
		"flowbite": "3.1.2",
		"flowbite-svelte": "0.48.6",
		"lucide-svelte": "^0.577.0",
		"monaco-editor": "^0.55.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.53.12",
		"svelte-check": "^4.4.5",
		"svelte-dnd-action": "^0.9.69",
		"svelte-highlight": "^7.9.0",
		"svelte-i18n": "^4.0.1",
		"svelte-multiselect": "^11.6.3",
		"svelte-outside-click": "^1.1.2",
		"svelte-resizable-columns": "^1.0.14",
		"sveltekit-search-params": "^4.0.0-next.0",
		"tailwindcss": "4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^7.0.0",
		"vitest": "^4.1.0"
	},
	"type": "module",
	"overrides": {
		"svelte-multiselect": {
			"svelte": "$svelte"
		},
		"@sveltejs/kit": {
			"cookie": "^1.0.0"
		}
	}
}

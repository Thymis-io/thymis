{
	"name": "thymis-frontend",
	"version": "0.7.2-dev",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"test": "npm run test:integration && npm run test:unit",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --plugin-search-dir . --check . && eslint .",
		"format": "prettier --plugin-search-dir . --write .",
		"test:integration": "playwright test",
		"test:integration:update-snapshots": "playwright test --update-snapshots",
		"test:unit": "vitest"
	},
	"devDependencies": {
		"@novnc/novnc": "npm:@elikoga/novnc@^1.6.0",
		"@playwright/test": "1.56.1",
		"@prgm/sveltekit-progress-bar": "^3.0.2",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.58.0",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/postcss": "^4.1.4",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.6.0",
		"@typescript-eslint/eslint-plugin": "^8.59.1",
		"@typescript-eslint/parser": "^8.59.1",
		"@xterm/addon-attach": "^0.12.0",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/addon-webgl": "^0.19.0",
		"@xterm/xterm": "^6.0.0",
		"@zerodevx/svelte-toast": "^0.9.6",
		"autoprefixer": "^10.5.0",
		"chart.js": "^4.5.1",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"eslint-plugin-unused-imports": "^4.4.1",
		"flowbite": "^3.1.2",
		"flowbite-svelte": "^0.48.6",
		"lucide-svelte": "^1.0.0",
		"monaco-editor": "^0.55.1",
		"postcss": "^8.5.12",
		"postcss-load-config": "^6.0.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.1",
		"svelte-chartjs": "^4.0.1",
		"svelte-check": "^4.4.6",
		"svelte-dnd-action": "^0.9.69",
		"svelte-highlight": "^7.9.0",
		"svelte-i18n": "^4.0.1",
		"svelte-multiselect": "^11.6.4",
		"svelte-outside-click": "^1.1.2",
		"svelte-resizable-columns": "^1.0.14",
		"sveltekit-search-params": "^4.0.0-next.0",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.59.1",
		"vite": "^7.3.1",
		"vitest": "^4.1.5",
		"yaml": "^2.8.3"
	},
	"type": "module",
	"overrides": {
		"svelte-multiselect": {
			"svelte": "$svelte"
		},
		"@sveltejs/kit": {
			"cookie": "^1.0.0"
		}
	}
}
